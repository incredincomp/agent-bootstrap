{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agent-bootstrap/schemas/implementation_tracker.schema.json",
  "title": "ImplementationTracker",
  "description": "Schema for validating the structured fields within IMPLEMENTATION_TRACKER.md (when represented as JSON for programmatic validation).",
  "type": "object",
  "required": ["schema_version", "repo_name", "current_phase", "objective", "milestones"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "repo_name": {
      "type": "string",
      "description": "Name of the target repository",
      "minLength": 1
    },
    "current_phase": {
      "type": "string",
      "description": "Human-readable description of the current project phase",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "description": "1–3 sentence description of the repository objective",
      "minLength": 1
    },
    "milestones": {
      "type": "array",
      "description": "Ordered list of project milestones",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Milestone"
      }
    },
    "decisions": {
      "type": "array",
      "description": "Key decisions made during the project",
      "items": {
        "$ref": "#/definitions/Decision"
      }
    },
    "files_created": {
      "type": "array",
      "description": "Files created or modified across all runs",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_status": {
      "type": "array",
      "description": "Validation checks performed and their results",
      "items": {
        "$ref": "#/definitions/ValidationCheck"
      }
    },
    "open_improvements": {
      "type": "array",
      "description": "Open improvement items or technical debt",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_milestone": {
      "$ref": "#/definitions/NextMilestone"
    }
  },
  "definitions": {
    "Milestone": {
      "type": "object",
      "required": ["number", "name", "status"],
      "additionalProperties": true,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["complete", "in_progress", "pending", "blocked"]
        },
        "notes": {
          "type": "string"
        },
        "completed_date": {
          "type": ["string", "null"],
          "description": "ISO 8601 date when this milestone was completed"
        }
      }
    },
    "Decision": {
      "type": "object",
      "required": ["decision", "reason"],
      "additionalProperties": true,
      "properties": {
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "alternative_considered": {
          "type": ["string", "null"]
        }
      }
    },
    "ValidationCheck": {
      "type": "object",
      "required": ["check", "result"],
      "additionalProperties": true,
      "properties": {
        "check": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "skipped", "partial"]
        },
        "method": {
          "type": ["string", "null"]
        },
        "date": {
          "type": ["string", "null"]
        }
      }
    },
    "NextMilestone": {
      "type": "object",
      "required": ["number", "name", "scope"],
      "additionalProperties": true,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "estimated_size": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
